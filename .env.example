# Frontend Environment Variables
# Copy this file to .env.local and configure your values

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api/v1
# Backward compatibility: VITE_API_URL is also supported in code,
# but VITE_API_BASE_URL is the preferred variable name.

# Application Name
VITE_APP_NAME=EasyIntern

# Application Version
VITE_APP_VERSION=1.0.0

# Debug Mode
VITE_DEBUG=false
